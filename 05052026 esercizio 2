.data
    mio_array: .word 10, 20, 30, 40, 50  # L'array da sommare
    lunghezza: .word 5                   # Numero di elementi
    msg_ris:   .asciiz "La somma dell'array è: "

.text
main:
    la $t0, mio_array      # $t0 è il nostro PUNTATORE all'indirizzo base
    lw $t1, lunghezza      # $t1 è il CONTATORE (quanti elementi restano)
    li $t2, 0              # $t2 è la somma parziale

loop:
    blez $t1, fine         # Se il contatore <= 0, esci dal ciclo
    
    lw $t3, 0($t0)         # CARICAMENTO: leggi il numero all'indirizzo in $t0
    add $t2, $t2, $t3      
    
    addi $t0, $t0, 4       
    addi $t1, $t1, -1      
    
    j loop                 

fine:
    # Stampa messaggio
    li $v0, 4
    la $a0, msg_ris
    syscall

    # Stampa il risultato contenuto in $t2
    move $a0, $t2
    li $v0, 1
    syscall

    # Exit
    li $v0, 10
    syscall
