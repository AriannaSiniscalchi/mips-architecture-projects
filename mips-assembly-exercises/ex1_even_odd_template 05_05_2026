.data
prompt_msg: .asciiz "Inserisci un intero: "
even_msg:   .asciiz "Pari"
odd_msg:    .asciiz "Dispari"

.text
.globl main
main:
    # Read an integer
    li $v0, 4           
    la $a0, prompt_msg
    syscall
    
    li $v0, 5           
    syscall
    move $t0, $v0  

    # Check whether it is even or odd
    # Logic: (number AND 1) -> if result is 0, it's even; if 1, it's odd.
    andi $t1, $t0, 1       # $t1 = $t0 & 1
    beq $t1, $zero, is_even # If $t1 == 0, jump to even_msg

is_odd:
    li $v0, 4
    la $a0, odd_msg
    syscall
    j exit                 # Jump to exit so we don't print "Even" too

is_even:
    li $v0, 4
    la $a0, even_msg
    syscall

exit:
    # Exit
    li $v0, 10          
    syscall